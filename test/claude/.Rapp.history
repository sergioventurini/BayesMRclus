abline(v = 0, col = "grey80", lty = 3)#
legend("topleft",#
       legend = c(sprintf("IVW (\u03b2 = %.3f)", beta_ivw),#
                  sprintf("MR-Egger (\u03b2 = %.3f)", b_eg)),#
