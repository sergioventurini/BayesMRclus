     ylab = expression(hat(Gamma)[j] ~ "(inv-norm log-insulin / allele)"),#
     main = "WHRadjBMI \u2192 Fasting Insulin: GWAS summary statistics")#
abline(0,       beta_ivw, col = "#2CA02C", lwd = 2, lty = 1)#
abline(int_eg,  b_eg,     col = "#FF7F0E", lwd = 2, lty = 2)#
